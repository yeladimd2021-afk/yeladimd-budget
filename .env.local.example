# ─── Supabase Configuration ──────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API

# Public keys (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER SIDE ONLY, never expose this in the browser!
# Used only by /api/admin/create-user to create new auth users.
# Find in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
