rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isUserActive() {
      return getUserData().isActive == true;
    }

    function isAdmin() {
      return isAuthenticated() && isUserActive() && getUserRole() == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && isUserActive() && getUserRole() in ['admin', 'editor'];
    }

    function isViewer() {
      return isAuthenticated() && isUserActive();
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated active user can read user list
      allow read: if isViewer();
      // Admin can create/update/delete users
      allow create, delete: if isAdmin();
      // Admin can update, or user can update their own lastLoginAt
      allow update: if isAdmin() || (
        isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt'])
      );
    }

    // ─── Budget Years ─────────────────────────────────────────────────────────
    match /years/{yearId} {
      allow read: if isViewer();
      allow create, update, delete: if isAdmin();
    }

    // ─── Categories ───────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if isViewer();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // ─── Expenses ─────────────────────────────────────────────────────────────
    match /expenses/{expenseId} {
      allow read: if isViewer();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // ─── Settings ─────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }
  }
}
